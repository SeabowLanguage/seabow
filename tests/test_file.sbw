#garbage_clock 0
#always_notnull true

import (
    "other" as o,
    "another" as ano
)

include (
    math as ma
)

void main()
{
    ldouble j = ma.PI;
    int128 i = ano.some_calcul(j)
    o.print_in_color(i, o.Color.RED);
    if (ano.is_error)
        exit "Ano error"
    
    try {
        i = o.calcul()
    } catch (DivisionByZero err) {
        print(err)
        i = 0
    } catch (error err) {
        print("Unhandled error: ", err)
        i = -1
    } finally {
        print("i: ", i)
    }

    delete j;
}